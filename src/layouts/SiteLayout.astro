---
import "../styles/global.css";
import { siteConfig } from "../config/site";
import { basePath, withBase } from "../lib/paths";

interface Frontmatter {
  title?: string;
  description?: string;
}

interface Props {
  title?: string;
  description?: string;
  frontmatter?: Frontmatter;
  pageType?: "auto" | "content" | "legal" | "landing";
  articleClassName?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  frontmatter,
  pageType = "auto",
  articleClassName,
  structuredData,
} = Astro.props as Props;
const pageTitle = Astro.props.title ?? frontmatter?.title ?? siteConfig.homeTitle;
const description =
  Astro.props.description ??
  frontmatter?.description ??
  siteConfig.defaultDescription;

const normalizedPathname = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(normalizedPathname, Astro.site ?? Astro.url).toString();
const homeHref = withBase("/");
const isHomePage = normalizedPathname === basePath;
const isLandingPage = isHomePage || pageType === "landing";
const resolvedPageType = isLandingPage ? "landing" : pageType === "auto" ? "legal" : pageType;
const title =
  isHomePage || pageTitle.includes(siteConfig.name)
    ? pageTitle
    : `${pageTitle} | ${siteConfig.name}`;
const organizationId = `${siteConfig.origin}#organization`;
const websiteId = `${siteConfig.origin}#website`;
const imageUrl = siteConfig.defaultSocialImageUrl;
const resolvedStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": organizationId,
    name: siteConfig.name,
    legalName: siteConfig.legalName,
    url: siteConfig.origin,
    logo: siteConfig.logoImageUrl,
    email: siteConfig.contactEmail,
    contactPoint: [
      {
        "@type": "ContactPoint",
        contactType: "customer support",
        email: siteConfig.supportEmail,
        url: new URL(siteConfig.supportHref, siteConfig.origin).toString(),
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": websiteId,
    name: siteConfig.name,
    url: siteConfig.origin,
    description: siteConfig.defaultDescription,
    publisher: {
      "@id": organizationId,
    },
  },
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eefbfd" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={isLandingPage ? "website" : "article"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta
      name="robots"
      content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1"
    />
    <link rel="alternate" type="text/plain" title="LLM context" href={withBase("/llms.txt")} />
    {resolvedStructuredData.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <script is:inline>
      (() => {
        const storageKey = "alekjaltuszyk-theme";
        const root = document.documentElement;

        const readStoredTheme = () => {
          try {
            const value = window.localStorage.getItem(storageKey);
            return value === "light" || value === "dark" ? value : null;
          } catch {
            return null;
          }
        };

        const writeStoredTheme = (value) => {
          try {
            window.localStorage.setItem(storageKey, value);
          } catch {
            // Ignore storage failures and keep the current session theme.
          }
        };

        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

        const getCurrentTheme = () => {
          const theme = root.dataset.theme;
          return theme === "light" || theme === "dark" ? theme : getSystemTheme();
        };

        const syncThemeButtons = () => {
          const currentTheme = getCurrentTheme();
          const nextTheme = currentTheme === "dark" ? "light" : "dark";
          const themeColor = document.querySelector('meta[name="theme-color"]');

          if (themeColor) {
            themeColor.setAttribute("content", currentTheme === "dark" ? "#071016" : "#eefbfd");
          }

          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            button.textContent = nextTheme === "dark" ? "Dark" : "Light";
            button.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
            button.setAttribute("title", `Switch to ${nextTheme} mode`);
            button.setAttribute("data-next-theme", nextTheme);
            button.setAttribute("aria-pressed", String(currentTheme === "dark"));
          });
        };

        const applyTheme = (theme, persist = true) => {
          root.dataset.theme = theme;
          if (persist) {
            writeStoredTheme(theme);
          }
          syncThemeButtons();
        };

        const storedTheme = readStoredTheme();
        if (storedTheme) {
          root.dataset.theme = storedTheme;
        }

        document.addEventListener(
          "DOMContentLoaded",
          () => {
            syncThemeButtons();

            document.addEventListener("click", (event) => {
              const target = event.target instanceof Element ? event.target.closest("[data-theme-toggle]") : null;
              if (!(target instanceof HTMLElement)) {
                return;
              }

              const nextTheme = target.dataset.nextTheme === "dark" ? "dark" : "light";
              applyTheme(nextTheme);
            });

            const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
            mediaQuery.addEventListener("change", () => {
              if (!readStoredTheme()) {
                syncThemeButtons();
              }
            });
          },
          { once: true },
        );
      })();
    </script>
    <title>{title}</title>
  </head>
  <body
    class:list={[
      resolvedPageType === "landing" && "is-home",
      resolvedPageType === "legal" && "is-legal",
      resolvedPageType === "content" && "is-content",
    ]}
  >
    <div class="site-backdrop" aria-hidden="true">
      <div class="site-backdrop__wash"></div>
      <div class="site-backdrop__orb site-backdrop__orb--coral"></div>
      <div class="site-backdrop__orb site-backdrop__orb--mint"></div>
      <div class="site-backdrop__grid"></div>
    </div>

    {!isLandingPage && (
      <header class="site-header">
        <div class="site-header__bar">
          <a class="site-header__home-link" href={homeHref}>{siteConfig.name}</a>
          <button class="theme-toggle" type="button" data-theme-toggle>Theme</button>
        </div>
      </header>
    )}

    <main class:list={["site-frame", resolvedPageType === "landing" && "landing-page"]}>
      {resolvedPageType === "landing" ? (
        <slot />
      ) : (
        <article
          class:list={[
            resolvedPageType === "legal" ? "legal-article" : "content-article",
            articleClassName,
          ]}
        >
          <slot />
        </article>
      )}
    </main>
  </body>
</html>

---
import "../styles/global.css";
import { siteConfig } from "../config/site";
import { basePath, withBase } from "../lib/paths";

interface Frontmatter {
  title?: string;
  description?: string;
}

interface Props {
  title?: string;
  description?: string;
  frontmatter?: Frontmatter;
  pageType?: "auto" | "content" | "legal" | "landing";
  articleClassName?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  canonicalHref?: string;
  robotsContent?: string;
}

const {
  frontmatter,
  pageType = "auto",
  articleClassName,
  structuredData,
  canonicalHref,
  robotsContent,
} = Astro.props as Props;
const pageTitle = Astro.props.title ?? frontmatter?.title ?? siteConfig.homeTitle;
const description =
  Astro.props.description ??
  frontmatter?.description ??
  siteConfig.defaultDescription;

const normalizedPathname = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalUrl = canonicalHref
  ? new URL(canonicalHref, Astro.site ?? Astro.url).toString()
  : new URL(normalizedPathname, Astro.site ?? Astro.url).toString();
const homeHref = withBase("/");
const isHomePage = normalizedPathname === basePath;
const isLandingPage = isHomePage || pageType === "landing";
const resolvedPageType = isLandingPage ? "landing" : pageType === "auto" ? "legal" : pageType;
const title =
  isHomePage || pageTitle.includes(siteConfig.name)
    ? pageTitle
    : `${pageTitle} | ${siteConfig.name}`;
const personId = `${siteConfig.origin}#person`;
const websiteId = `${siteConfig.origin}#website`;
const imageUrl = siteConfig.defaultSocialImageUrl;
const resolvedStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": personId,
    name: siteConfig.identity.fullName,
    alternateName: [siteConfig.identity.preferredName, ...siteConfig.identity.asciiNameVariants],
    givenName: "Aleksander",
    familyName: "Jałtuszyk",
    url: siteConfig.origin,
    image: imageUrl,
    description: siteConfig.aiDiscovery.summary,
    jobTitle: "Software Engineer",
    knowsAbout: siteConfig.identity.focusAreas,
    email: siteConfig.contactEmail,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": websiteId,
    name: siteConfig.identity.preferredName,
    alternateName: [siteConfig.identity.fullName, ...siteConfig.identity.asciiNameVariants],
    url: siteConfig.origin,
    description: siteConfig.defaultDescription,
    about: { "@id": personId },
    author: { "@id": personId },
    creator: { "@id": personId },
    publisher: { "@id": personId },
  },
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.legalName} />
    <meta name="creator" content={siteConfig.identity.preferredName} />
    <meta name="theme-color" content="#020406" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="author" href={homeHref} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={isLandingPage ? "website" : "article"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta
      name="robots"
      content={
        robotsContent ?? "index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1"
      }
    />
    <link rel="alternate" type="text/plain" title="LLM context" href={withBase("/llms.txt")} />
    <link
      rel="alternate"
      type="text/plain"
      title="Expanded LLM context"
      href={withBase("/llms-full.txt")}
    />
    <link rel="alternate" type="text/plain" title="Humans summary" href={withBase("/humans.txt")} />
    {resolvedStructuredData.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
  </head>
  <body
    class:list={[
      resolvedPageType === "landing" && "is-landing",
      isHomePage && "is-root-home",
      resolvedPageType === "legal" && "is-legal",
      resolvedPageType === "content" && "is-content",
    ]}
  >
    <div class="site-backdrop" aria-hidden="true">
      <div class="site-backdrop__wash"></div>
      <div class="site-backdrop__orb site-backdrop__orb--coral"></div>
      <div class="site-backdrop__orb site-backdrop__orb--mint"></div>
      <div class="site-backdrop__grid"></div>
    </div>

    {!isLandingPage && (
      <header class="site-header">
        <div class="site-header__bar">
          <a class="site-header__home-link" href={homeHref}>{siteConfig.name}</a>
        </div>
      </header>
    )}

    <main class:list={["site-frame", resolvedPageType === "landing" && "landing-page"]}>
      {resolvedPageType === "landing" ? (
        <slot />
      ) : (
        <article
          class:list={[
            resolvedPageType === "legal" ? "legal-article" : "content-article",
            articleClassName,
          ]}
        >
          <slot />
        </article>
      )}
    </main>

    {resolvedPageType === "landing" && (
      <script>
        import "../scripts/landing/init";
      </script>
    )}
  </body>
</html>

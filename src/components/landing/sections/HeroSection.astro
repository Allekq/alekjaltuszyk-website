---
import { planKeptConfig } from "../../../config/site";
import ActionButton from "../ui/ActionButton.astro";

const rippleWords = Array.from({ length: 6 }, (_, index) => ({
  text: "PlanKept",
  ring: index + 1,
}));

const statusCards = [
  {
    title: "Keep the plan visible",
    body: "One home for the promise you meant to follow through on after the first spark wears off.",
  },
  {
    title: "Nudge at the right time",
    body: "Designed around small, timely reminders instead of giant dashboards.",
  },
  {
    title: "Built for phone first",
    body: "The public site and the product direction both start with mobile in mind.",
  },
];
---

<section id="home" class="landing-section hero-section">
  <div class="landing-section__inner hero-section__inner">
    <div class="hero-section__copy" data-reveal>
      <p class="section-kicker">Mobile-first launch surface</p>
      <h1 class="hero-section__title">{planKeptConfig.tagline}</h1>
      <p class="hero-section__body">{planKeptConfig.heroDescription}</p>

      <div class="hero-section__actions">
        <ActionButton href={planKeptConfig.wishListGuideHref}>
          {planKeptConfig.ctas.primary}
        </ActionButton>
        <ActionButton href="#mobile" variant="secondary">
          {planKeptConfig.ctas.secondary}
        </ActionButton>
        <ActionButton href={planKeptConfig.directoryHref} variant="ghost">
          {planKeptConfig.ctas.directory}
        </ActionButton>
      </div>

      <div class="hero-section__chips">
        <span>Public page at /apps/PlanKept/</span>
        <span>Support + legal live now</span>
        <span>Ready for deploy-on-main</span>
      </div>
    </div>

    <div class="hero-section__visual" data-reveal data-reveal-early>
      <div class="brand-ripple" aria-hidden="true">
        {rippleWords.map((item) => (
          <span class={`brand-ripple__ring brand-ripple__ring--${item.ring}`}>{item.text}</span>
        ))}
      </div>

      <div class="plan-phone">
        <div class="plan-phone__shell">
          <div class="plan-phone__status">
            <span class="plan-phone__dot"></span>
            <span>Plan in motion</span>
          </div>

          <div class="plan-phone__hero-card">
            <p class="plan-phone__eyebrow">Today</p>
            <h2>Finish the evening reset before 8:30.</h2>
            <p>
              A simple plan, kept visible long enough to actually become real.
            </p>
          </div>

          <div class="plan-phone__stack">
            {statusCards.map((card) => (
              <article class="plan-phone__stack-card">
                <h3>{card.title}</h3>
                <p>{card.body}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="plan-phone__glow plan-phone__glow--mint"></div>
        <div class="plan-phone__glow plan-phone__glow--gold"></div>
      </div>
    </div>
  </div>
</section>

---
import { siteConfig } from "../../../config/site";
import { withBase } from "../../../lib/paths";

const heroVideoPath = withBase("/media/home/hero-energy-loop.mp4");
const heroNameLines = siteConfig.name.split(" ");
---

<section class="home-video-hero" id="home">
  <div class="home-video-hero__media" aria-hidden="true">
    <video class="home-video-hero__video" autoplay loop muted playsinline preload="metadata">
      <source src={heroVideoPath} type="video/mp4" />
    </video>
  </div>

  <div class="home-video-hero__inner">
    <h1 class="home-video-hero__title">
      {heroNameLines.map((line) => (
        <span>{line}</span>
      ))}
    </h1>
  </div>
</section>

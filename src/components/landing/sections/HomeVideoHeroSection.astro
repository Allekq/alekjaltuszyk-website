---
import { siteConfig } from "../../../config/site";
import { withBase } from "../../../lib/paths";

const heroVideoPath = withBase("/media/home/hero-energy-loop.mp4");
const heroNameLines = siteConfig.preferredName.split(" ");
---

<section class="home-video-hero" id="home">
  <div class="home-video-hero__media" aria-hidden="true">
    <video class="home-video-hero__video" autoplay loop muted playsinline preload="metadata">
      <source src={heroVideoPath} type="video/mp4" />
    </video>
  </div>

  <div class="home-video-hero__inner">
    <div class="home-video-hero__copy">
      <p class="home-video-hero__kicker">Software engineer / AI systems / Unity craft</p>
      <h1 class="home-video-hero__title">
        {heroNameLines.map((line) => (
          <span>{line}</span>
        ))}
      </h1>
      <p class="home-video-hero__summary">
        Building products where intelligence, behavior, and a little useful pressure meet.
      </p>
      <a class="home-video-hero__cue" href="#current-products">Current work</a>
    </div>
  </div>
</section>

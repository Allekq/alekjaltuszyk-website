---
import { siteConfig } from "../../../config/site";
---

<footer class="site-footer">
  <div class="site-footer__inner landing-surface">
    <a class="site-footer__brand" href={siteConfig.homeHref}>{siteConfig.name}</a>

    <nav class="site-footer__links" aria-label="Footer">
      {siteConfig.footerLinks.map((link) => (
        <a
          href={link.href}
          target={"external" in link ? "_blank" : undefined}
          rel={"external" in link ? "noreferrer" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <p class="site-footer__copy">{siteConfig.footerText}</p>
  </div>
</footer>

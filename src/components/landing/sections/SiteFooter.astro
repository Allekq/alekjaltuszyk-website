---
import { siteConfig } from "../../../config/site";

interface FooterLink {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  brand?: string;
  brandHref?: string;
  links?: readonly FooterLink[];
  showBrand?: boolean;
}

const {
  brand = siteConfig.name,
  brandHref = siteConfig.homeHref,
  links = siteConfig.footerLinks,
  showBrand = true,
} = Astro.props as Props;
---

<footer class="site-footer">
  <div class="site-footer__inner landing-surface">
    {showBrand ? (
      <a class="site-footer__brand" href={brandHref}>{brand}</a>
    ) : null}

    <nav class="site-footer__links" aria-label="Footer">
      {links.map((link) => (
        <a
          href={link.href}
          target={"external" in link && link.external ? "_blank" : undefined}
          rel={"external" in link && link.external ? "noreferrer" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <p class="site-footer__copy">{siteConfig.footerText}</p>
  </div>
</footer>
